# Tắt HMR (tránh trang tự reload). `bun run start` đã set DISABLE_BUN_HMR=1.
# Nếu systemd gọi `bun ./server.ts` trực tiếp, thêm: DISABLE_BUN_HMR=1
#
# (Tuỳ chọn) Sau khi `bun upgrade` (Bun mới), có thể thêm NODE_ENV=production để React
# bundle production — nếu gặp lỗi jsxDEV, bỏ NODE_ENV hoặc cập nhật Bun.

# Cổng server (mặc định 3000 nếu không khai báo)
PORT=3000

# Admin login (đổi trong production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Trang quản trị: http://localhost:3000/admin (đổi số cổng nếu PORT khác)
