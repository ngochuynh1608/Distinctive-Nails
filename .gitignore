# Runtime data + user uploads
# - `server.ts` reads `data/site.json` -> keep the template file committed
# - User uploads are written to `public/uploads/*` -> ignore uploaded files, but keep `.gitkeep`
data/*
!data/site.json

public/uploads/*
!public/uploads/.gitkeep
